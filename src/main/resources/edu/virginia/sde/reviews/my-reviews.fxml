<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.*?>
<?import java.util.*?>
<?import javafx.scene.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="edu.virginia.sde.reviews.MyReviewsController"
             prefHeight="720" prefWidth="1280">

    <top>
        <BorderPane style="-fx-padding: 10;">
            <left>
                <Button text="← Back" onAction="#onBack"/>
            </left>
            <center>
                <Label text="My Reviews" style="-fx-font-size: 18px; -fx-font-weight: bold;"/>
            </center>
        </BorderPane>
    </top>

    <center>
        <TableView fx:id="reviewTable">
            <columns>
                <TableColumn text="Subject" fx:id="subjectCol"/>
                <TableColumn text="Number" fx:id="numberCol"/>
                <TableColumn text="Title" fx:id="titleCol" />
                <TableColumn text="Rating" fx:id="ratingCol"/>
                <TableColumn text="Comment" fx:id="commentCol"/>
            </columns>
        </TableView>
    </center>

</BorderPane>