<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.*?>
<?import java.util.*?>
<?import javafx.scene.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="edu.virginia.sde.reviews.CourseSearchController"
            prefHeight="720" prefWidth="1280">
    <top>
        <VBox spacing="12" alignment="CENTER">

            <GridPane hgap="10" vgap="12" alignment="CENTER">
                <Label text="Subject" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                <Label text="Number" GridPane.rowIndex="0" GridPane.columnIndex="1"/>
                <Label text="Title" GridPane.rowIndex="0" GridPane.columnIndex="2"/>
                <TextField fx:id="subjectField" promptText="Subject" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
                <TextField fx:id="numberField" promptText="Number" GridPane.rowIndex="1" GridPane.columnIndex="1"/>
                <TextField fx:id="titleField" promptText="Title" GridPane.rowIndex="1" GridPane.columnIndex="2"/>
            </GridPane>

            <HBox  spacing="12" alignment="CENTER">
                <Button text="Search" fx:id="searchButton" onAction="#onSearch"/>
                <Button text="Add Course" fx:id="addButton" onAction="#onAdd"/>
            </HBox>
        </VBox>
    </top>

    <center>
        <TableView fx:id="courseTable">
            <columns>
                <TableColumn text="Subject" fx:id="subjectCol"/>
                <TableColumn text="Number" fx:id="numberCol"/>
                <TableColumn text="Title" fx:id="titleCol"/>
                <TableColumn text="Avg Rating" fx:id="ratingCol"/>
            </columns>
        </TableView>
    </center>

    <bottom>
        <VBox spacing="12" alignment="CENTER">
            <Button text="Log Out" fx:id="logOutButton" onAction="#onLogout"/>
        </VBox>
    </bottom>
</BorderPane>