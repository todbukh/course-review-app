<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.*?>
<?import java.util.*?>
<?import javafx.scene.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>


<GridPane xmlns:fx="http://javafx.com/fxml"
          fx:controller="edu.virginia.sde.reviews.RegisterController"
          alignment="CENTER" hgap="10" vgap="10">

    <Label text="Username:" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
    <TextField fx:id="usernameField" promptText="New Username" GridPane.rowIndex="0" GridPane.columnIndex="1"/>

    <Label text="Password:" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
    <PasswordField fx:id="passwordField" promptText="Password" GridPane.rowIndex="1" GridPane.columnIndex="1"/>

    <Label text="Confirm password:" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
    <PasswordField fx:id="confirmPasswordField" promptText="Confirm Password" GridPane.rowIndex="2" GridPane.columnIndex="1"/>

    <Button text="Submit" fx:id="submitButton" onAction="#onSubmit" GridPane.rowIndex="4" GridPane.columnIndex="1"/>
    <Button text="Cancel" fx:id="cancelButton" onAction="#onCancel" GridPane.rowIndex="5" GridPane.columnIndex="1"/>

</GridPane>
