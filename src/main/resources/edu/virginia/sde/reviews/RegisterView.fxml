<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.*?>
<?import java.util.*?>
<?import javafx.scene.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>


<GridPane xmlns:fx="http://javafx.com/fxml"
          fx:controller="edu.virginia.sde.reviews.RegisterController"
          alignment="CENTER" hgap="10" vgap="10">

    <TextField fx:id="usernameField" promptText="New Username" GridPane.rowIndex="0"/>
    <PasswordField fx:id="passwordField" promptText="Password" GridPane.rowIndex="1"/>
    <PasswordField fx:id="confirmPasswordField" promptText="Confirm Password" GridPane.rowIndex="2"/>

    <Button text="Submit" fx:id="submitButton" onAction="#onSubmit" GridPane.rowIndex="3"/>
    <Button text="Cancel" fx:id="cancelButton" onAction="#onCancel" GridPane.rowIndex="4"/>

</GridPane>
