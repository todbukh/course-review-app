<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.*?>
<?import java.util.*?>
<?import javafx.scene.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="edu.virginia.sde.reviews.RegisterController"
            prefHeight="720" prefWidth="1280">
    <top>
        <StackPane styleClass="header">
            <Label text="Register" styleClass="title"/>
            <BorderPane>
                <left>
                    <Button text="← Back" styleClass="header-button" onAction="#onBack"/>
                </left>
            </BorderPane>
        </StackPane>
    </top>
    <center>
        <VBox styleClass="spaced" alignment="CENTER">

            <GridPane hgap="10" vgap="12" alignment="CENTER">
                <Label text="Username:" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                <TextField fx:id="usernameField" promptText="Choose a username" GridPane.rowIndex="0" GridPane.columnIndex="1"/>

                <Label text="Password:" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
                <PasswordField fx:id="passwordField" promptText="Choose a password" GridPane.rowIndex="1" GridPane.columnIndex="1"/>

                <Label text="Confirm:" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
                <PasswordField fx:id="passwordConfirmField" promptText="Confirm password" GridPane.rowIndex="2" GridPane.columnIndex="1"/>
            </GridPane>

            <Button text="Register" fx:id="registerButton" onAction="#onRegister"/>
        </VBox>
    </center>
</BorderPane>