<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.*?>
<?import java.util.*?>
<?import javafx.scene.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
          fx:controller="edu.virginia.sde.reviews.LoginController">
    <center>
        <VBox spacing="12" alignment="CENTER">
            <Label text="Login"/>

            <GridPane hgap="10" vgap="12" alignment="CENTER">
                <Label text="Username:" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                <TextField fx:id="usernameField" promptText="New Username" GridPane.rowIndex="0" GridPane.columnIndex="1"/>

                <Label text="Password:" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
                <PasswordField fx:id="passwordField" promptText="Password" GridPane.rowIndex="1" GridPane.columnIndex="1"/>
            </GridPane>
            <Button text="Log In" fx:id="loginButton" onAction="#onLogin"/>
            <Button text="Register" fx:id="registerButton" onAction="#onRegister"/>
        </VBox>
    </center>
</BorderPane>